{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "template.minimalista",
  "version": "2.5.0",
  "description": "Minimalista template assets",
  "license": "GPL-2.0-or-later",
  "assets": [
    {
      "name": "template.minimalista.jquery",
      "type": "script",
      "uri": "jquery-4.0.0.min.js"
    },
    {
      "name": "template.minimalista.jquery-noconflict",
      "type": "script",
      "uri": "jquery-noconflict.js",
      "dependencies": [
        "template.minimalista.jquery"
      ]
    },
    {
      "name": "template.minimalista.bootstrap",
      "type": "style",
      "uri": "bootstrap.min.css"
    },
    {
      "name": "template.minimalista.bootstrap",
      "type": "script",
      "uri": "bootstrap.bundle.min.js",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "template.minimalista.fontawesome",
      "type": "style",
      "uri": "all.min.css"
    },
    {
      "name": "template.minimalista.fontawesome",
      "type": "script",
      "uri": "all.min.js",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "template.minimalista.animate",
      "type": "style",
      "uri": "animate.min.css",
      "version": "4.1.1"
    },
    {
      "name": "template.minimalista.main",
      "type": "style",
      "uri": "template.css",
      "dependencies": [
        "template.minimalista.bootstrap",
        "template.minimalista.animate"
      ]
    },
    {
      "name": "template.minimalista.main",
      "type": "script",
      "uri": "template.js",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "template.minimalista.responsive",
      "type": "style",
      "uri": "responsive.css",
      "dependencies": [
        "template.minimalista.main"
      ]
    }
  ]
}
